# CityWatch Environment Variables
# Copy this file to .env.local and fill in YOUR values (never commit .env.local)

# Firebase — Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_optional

# Map + nearest authorities use Leaflet/OpenStreetMap (free, no API key/billing).
# Note: Google Places can provide better hospital phone numbers, but it requires a
# billing-enabled Google Cloud key. This project stays on free OSM/Nominatim.

# Groq AI — recommended: https://console.groq.com/keys (key starts with gsk_)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Gemini AI — optional fallback: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.0-flash-lite

# Optional free fallback inbox for agent auto-dispatch emails (FormSubmit).
# When OSM has no phone/email, CityWatch still notifies this address for severity-5 trusted reports.
# VITE_ESCALATION_EMAIL=ops@yourcity.example.com

# Environment
VITE_APP_ENV=development
